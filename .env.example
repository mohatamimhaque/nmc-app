# ─── Supabase ───────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="your-publishable-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_JWT_SECRET="your-jwt-secret"
SUPABASE_PUBLISHABLE_KEY="your-publishable-key"
SUPABASE_SECRET_KEY="your-secret-key"
SUPABASE_URL="https://your-project.supabase.co"

# ─── Postgres ───────────────────────────────────────────
POSTGRES_DATABASE="postgres"
POSTGRES_HOST="your-postgres-host"
POSTGRES_PASSWORD="your-postgres-password"
POSTGRES_PRISMA_URL="postgres://user:password@host:port/database?sslmode=require&pgbouncer=true"
POSTGRES_URL="postgres://user:password@host:port/database?sslmode=require"
POSTGRES_URL_NON_POOLING="postgres://user:password@host:port/database?sslmode=require"
POSTGRES_USER="postgres"

# ─── Cloudflare R2 ──────────────────────────────────────
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=nmc
R2_PUBLIC_URL=https://pub-your-bucket-id.r2.dev

# ─── Email (Resend) ─────────────────────────────────────
RESEND_API_KEY=re_your_api_key
CONTACT_FORM_RECIPIENT=admin@yourdomain.com

# ─── App ────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Admit Card Security & Generator ────────────────────
ADMIT_CARD_SECRET_KEY="your-admit-card-secret-key"
ADMIT_CARD_GENERATOR_URL="http://127.0.0.1:8080"
